---
layout: base.njk
pagination:
  data: plans
  size: 1
  alias: planData
permalink: "/fr/plans/{{ planData.slug }}/"
---

{% set plan = planData | translatePlan('fr') %}
{% set lang = 'fr' %}
{% set title = plan.title %}
{% set description = plan.description %}
{% set ogImage = plan.images[0] + '?width=1200&quality=80&format=webp' %}
{% set bodyClass = 'product-page' %}
{% set pageScripts = ['countdown', 'gallery', 'checkout', 'faq'] %}

<!-- JSON-LD Product -->
{% set jsonLd %}{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ plan.title }}",
  "description": "{{ plan.description }}",
  "image": {{ plan.images | dump }},
  "brand": {
    "@type": "Brand",
    "name": "WooPlans"
  },
  "offers": {
    "@type": "Offer",
    "price": {{ planData.price }},
    "priceCurrency": "XAF",
    "availability": "https://schema.org/InStock",
    "url": "{{ site.url }}/fr/plans/{{ planData.slug }}/"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ planData.rating }}",
    "reviewCount": "{{ planData.reviews }}"
  }
}{% endset %}

<div class="product-page">
  <div class="container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/{{ lang }}/">
        {{ 'nav.back_to_catalog' | t(lang) }}
      </a>
      <span class="discount-badge-inline">-50% {{ 'common.today' | t(lang) }}</span>
    </nav>
    
    <div class="product-layout">
      <!-- Colonne principale -->
      <div class="product-main">
        
        <!-- Galerie -->
        <section class="gallery" aria-label="{{ 'product.discover_3d' | t(lang) }}">
          <div class="gallery-main">
            <img id="gallery-main-img" 
                 src="{{ planData.images[0] }}?width=800&quality=80&format=webp" 
                 alt="{{ plan.title }}" 
                 width="800" 
                 height="500"
                 loading="eager">
            <span class="gallery-badge">{{ planData.typeLabel }} · {{ planData.id }}</span>
            
            <button class="gallery-nav prev" aria-label="Previous image" onclick="prevImage()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            <button class="gallery-nav next" aria-label="Next image" onclick="nextImage()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>
          </div>
          
          <div class="gallery-thumbs" role="tablist" aria-label="Image thumbnails">
            {% for image in planData.images %}
            <button class="gallery-thumb {{ 'active' if loop.first }}" 
                    role="tab"
                    aria-label="Image {{ loop.index }}"
                    aria-selected="{{ 'true' if loop.first else 'false' }}"
                    onclick="setGalleryImage({{ loop.index0 }})">
              <img src="{{ image }}?width=200&quality=60&format=webp" 
                   alt="" 
                   width="200" 
                   height="125"
                   loading="lazy">
            </button>
            {% endfor %}
          </div>
        </section>
        
        <!-- Titre et CTA Mobile -->
        <section class="product-hero">
          <h1>{{ 'product.get_plan' | t(lang) }} {{ plan.title }}</h1>
          <p class="lead">{{ 'product.download_now' | t(lang) }}</p>
          
          <div class="mobile-cta">
            <div class="price-display">
              <span class="price-old">{{ planData.originalPrice | formatPrice }}</span>
              <span class="price-current">
                {{ planData.price | formatPrice }}
                <span class="currency">Fcfa</span>
              </span>
            </div>
            <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-primary">
              🛒 {{ 'common.buy_now' | t(lang) }}
            </a>
          </div>
        </section>
        
        <!-- Section 3D -->
        <section class="section-3d">
          <h2>{{ 'product.discover_3d' | t(lang) }}</h2>
          <p>{{ 'product.visualize_details' | t(lang) }}</p>
        </section>
        
        <!-- Partage -->
        {% include "share-buttons.njk" %}
        
        <!-- Présentation -->
        <article class="product-details">
          <h2>{{ 'product.presentation' | t(lang) }} {{ plan.title }}</h2>
          <p class="lead">{{ plan.subtitle }}</p>
          <p>{{ plan.description }}</p>
          
          <!-- Spécifications -->
          <div class="specs-grid">
            <div class="spec-item">
              <span class="spec-icon">📐</span>
              <div class="spec-content">
                <span class="spec-value">{{ planData.surface }} m²</span>
                <span class="spec-label">{{ 'product.specs.surface' | t(lang) }}</span>
              </div>
            </div>
            <div class="spec-item">
              <span class="spec-icon">🛏️</span>
              <div class="spec-content">
                <span class="spec-value">{{ planData.rooms }}</span>
                <span class="spec-label">{{ 'product.specs.rooms' | t(lang) }}</span>
              </div>
            </div>
            <div class="spec-item">
              <span class="spec-icon">🚿</span>
              <div class="spec-content">
                <span class="spec-value">{{ planData.bathrooms }}</span>
                <span class="spec-label">{{ 'product.specs.bathrooms' | t(lang) }}</span>
              </div>
            </div>
            <div class="spec-item">
              <span class="spec-icon">🏢</span>
              <div class="spec-content">
                <span class="spec-value">{{ planData.floors }}</span>
                <span class="spec-label">{{ 'product.specs.floors' | t(lang) }}</span>
              </div>
            </div>
            {% if planData.terrain %}
            <div class="spec-item">
              <span class="spec-icon">📍</span>
              <div class="spec-content">
                <span class="spec-value">{{ planData.terrain }}</span>
                <span class="spec-label">{{ 'product.specs.terrain' | t(lang) }}</span>
              </div>
            </div>
            {% endif %}
            {% if planData.estimateCost %}
            <div class="spec-item">
              <span class="spec-icon">💰</span>
              <div class="spec-content">
                <span class="spec-value">{{ planData.estimateCost }}</span>
                <span class="spec-label">{{ 'product.specs.estimate' | t(lang) }}</span>
              </div>
            </div>
            {% endif %}
          </div>
          
          <!-- Liste pièces -->
          {% if plan.roomsList %}
          <ul class="rooms-list">
            {% for room in plan.roomsList %}
            <li>{{ room }}</li>
            {% endfor %}
          </ul>
          {% endif %}
          
          <!-- CTA milieu de page -->
          <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-primary btn-lg btn-block" style="margin-top: 2rem;">
            🛒 {{ 'common.buy_now' | t(lang) }}
          </a>
          <p class="payment-info">{{ 'common.secure_payment' | t(lang) }}</p>
        </article>
        
        <!-- CTA après présentation -->
        <section class="cta-section" style="text-align: center; padding: 2rem 0;">
          <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-gold btn-xl btn-block">
            {{ 'checkout.pay_button' | t(lang) }}
          </a>
          <p class="payment-info">{{ 'common.secure_payment' | t(lang) }}</p>
        </section>
        
        <!-- Offre Flash -->
        <section class="flash-offer-section" id="checkout">
          <div class="offer-card">
            <h3>{{ 'product.flash_offer' | t(lang) }}</h3>
            
            <div class="offer-countdown">
              <p>{{ 'product.ends_in' | t(lang) }}</p>
              {% countdown %}
            </div>
            
            <div class="price-comparison">
              <span class="price-strikethrough">{{ planData.originalPrice | formatPrice }}</span>
              <span class="price-highlight">{{ planData.price | formatPrice }}</span>
            </div>
            
            <!-- Mockup -->
            <div class="mockup-container">
              <img src="/images/mockups/{{ planData.slug }}-mockup.png" 
                   alt="Aperçu du plan PDF" 
                   class="mockup-preview"
                   loading="lazy"
                   width="400"
                   height="500">
            </div>
            
            <!-- Ce que vous obtenez -->
            <div class="you-get">
              <h4>{{ 'product.you_get' | t(lang) }}</h4>
              <ul>
                <li>{{ 'product.includes.plan' | t(lang) }}</li>
                <li>{{ 'product.includes.quote' | t(lang) }}</li>
                <li>{{ 'product.includes.support' | t(lang) }}</li>
              </ul>
            </div>
            
            <!-- Bonus -->
            <div class="bonus-box">
              <strong>🎁 {{ 'product.bonus' | t(lang) }}</strong>
              <p>{{ plan.bonusTitle }}</p>
            </div>
            
            <!-- CTA final -->
            <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-gold btn-xl btn-block" data-track="checkout_click" data-plan="{{ planData.id }}">
              {{ 'checkout.pay_button' | t(lang) }} →
            </a>
            <p class="payment-info">{{ 'checkout.redirect_info' | t(lang) }}</p>
          </div>
        </section>
        
        <!-- Témoignages -->
        {% include "testimonials.njk" %}
        
        <!-- CTA après témoignages -->
        <section class="cta-section" style="text-align: center; padding: 2rem 0; background: var(--bg-secondary); border-radius: var(--radius-lg); margin: 2rem 0;">
          <h3 style="margin-bottom: 1rem;">Planifier votre projet maintenant</h3>
          <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-gold btn-lg btn-block">
            {{ 'checkout.pay_button' | t(lang) }}
          </a>
          <p class="payment-info">{{ 'common.secure_payment' | t(lang) }}</p>
        </section>
        
        <!-- FAQ -->
        {% include "faq.njk" %}
        
        <!-- CTA final après FAQ -->
        <section class="cta-section" style="text-align: center; padding: 2rem 0; margin: 2rem 0;">
          <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-gold btn-xl btn-block">
            Je démarre mon projet maintenant
          </a>
          <p class="payment-info">{{ 'common.secure_payment' | t(lang) }}</p>
        </section>
        
      </div>
      
      <!-- Sidebar Desktop -->
      <aside class="product-sidebar" aria-label="Product information">
        <div class="sticky-card">
          <h3>{{ 'product.get_plan' | t(lang) }}</h3>
          <p>{{ plan.subtitle }}</p>
          
          <div class="price-display">
            <span class="price-old">{{ planData.originalPrice | formatPrice }}</span>
            <span class="price-current">
              {{ planData.price | formatPrice }}
              <span class="currency">Fcfa</span>
            </span>
          </div>
          
          <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-primary btn-block">
            🛒 {{ 'checkout.pay_button' | t(lang) }}
          </a>
          <p class="payment-info">{{ 'common.secure_payment' | t(lang) }}</p>
          
          <div class="trust-badges" style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              {{ 'checkout.satisfaction' | t(lang) }}
            </div>
            <div class="trust-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              {{ 'checkout.instant_delivery' | t(lang) }}
            </div>
          </div>
        </div>
      </aside>
    </div>
    
    <!-- Plans similaires -->
    <section class="similar-plans" aria-label="{{ 'product.similar_plans' | t(lang) }}">
      <h2>{{ 'product.similar_plans' | t(lang) }}</h2>
      <p>{{ 'product.similar_subtitle' | t(lang) }}</p>
      
      <div class="plans-grid">
        {% for similar in collections.plansByType[planData.type] %}
          {% if similar.id != planData.id and loop.index <= 3 %}
            {% set similarPlan = similar | translatePlan(lang) %}
            <article class="card">
              <div class="card-image">
                <img src="{{ similar.images[0] }}?width=400&quality=75&format=webp" 
                     alt="{{ similarPlan.title }}"
                     loading="lazy"
                     width="400"
                     height="300">
                <span class="card-badge">{{ similar.typeLabel }}</span>
              </div>
              <div class="card-content">
                <span class="card-type">{{ similar.typeLabel }}</span>
                <h3 class="card-title">{{ similarPlan.title }}</h3>
                <p class="card-subtitle">{{ similarPlan.subtitle }}</p>
                <div class="card-specs">
                  <span class="card-spec">
                    <span class="spec-icon">📐</span>
                    {{ similar.surface }} m²
                  </span>
                  <span class="card-spec">
                    <span class="spec-icon">🛏️</span>
                    {{ similar.rooms }} {{ 'common.bedrooms' | t(lang) }}
                  </span>
                  <span class="card-spec">
                    <span class="spec-icon">🚿</span>
                    {{ similar.bathrooms }} {{ 'common.bathrooms' | t(lang) }}
                  </span>
                </div>
                <div class="card-footer">
                  <span class="card-price">{{ similar.price | formatPrice }}</span>
                  <a href="/{{ lang }}/plans/{{ similar.slug }}/" class="btn btn-sm btn-secondary">
                    {{ 'common.view' | t(lang) }}
                  </a>
                </div>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  </div>
</div>

<!-- Sticky Bottom Bar (Mobile) -->
<div class="sticky-bottom-bar" style="position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg-secondary); border-top: 1px solid var(--border); padding: 0.75rem 1rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; z-index: 100;">
  <div style="display: flex; flex-direction: column;">
    <span style="font-size: 0.75rem; color: var(--text-muted);">Plan et devis {{ plan.title }}</span>
    <span style="font-weight: 700; color: var(--gold);">{{ planData.price | formatPrice }}</span>
  </div>
  <a href="/{{ lang }}/checkout/?plan={{ planData.slug }}" class="btn btn-gold btn-sm" style="white-space: nowrap;">
    Télécharger
  </a>
</div>

<style>
  @media (min-width: 1024px) {
    .sticky-bottom-bar {
      display: none !important;
    }
  }
  /* Ajouter du padding au body pour compenser la barre sticky */
  body {
    padding-bottom: 70px;
  }
  @media (min-width: 1024px) {
    body {
      padding-bottom: 0;
    }
  }
</style>

<!-- Données pour JavaScript -->
<script>
  window.planData = {
    id: '{{ planData.id }}',
    title: '{{ plan.title }}',
    price: {{ planData.price }},
    images: {{ planData.images | dump | safe }},
    slug: '{{ planData.slug }}'
  };
</script>
