---
layout: base.njk
permalink: "/en/"
---

{% set lang = 'en' %}
{% set title = 'Home' %}

<!-- Hero -->
<section class="hero" style="padding: 4rem 0; text-align: center;">
  <div class="container">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem; line-height: 1.2;">
      {{ 'site.tagline' | t(lang) }}
    </h1>
    <p class="lead" style="max-width: 600px; margin: 0 auto 2rem;">
      {{ 'site.description' | t(lang) }}
    </p>
    <a href="#catalog" class="btn btn-primary btn-lg">
      Browse Plans
    </a>
  </div>
</section>

<!-- Catalog -->
<section id="catalog" class="catalog" style="padding: 4rem 0;">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: 3rem;">Our Plans</h2>
    
    <div class="plans-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
      {% for plan in plans %}
        {% set planLocalized = plan | translatePlan(lang) %}
        <article class="card">
          <div class="card-image" style="position: relative; aspect-ratio: 4/3; overflow: hidden; border-radius: 12px 12px 0 0;">
            <img src="{{ plan.images[0] }}?width=600&quality=75&format=webp" 
                 alt="{{ planLocalized.title }}"
                 loading="lazy"
                 style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;">
            <span class="card-badge" style="position: absolute; top: 1rem; left: 1rem; background: var(--gold); color: #000; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">
              {{ plan.typeLabelEn }}
            </span>
          </div>
          <div class="card-content" style="padding: 1.5rem;">
            <h3 style="font-size: 1.25rem; margin-bottom: 0.5rem;">{{ planLocalized.title }}</h3>
            <p style="color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 1rem;">
              {{ planLocalized.subtitle }}
            </p>
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <span style="font-size: 1.5rem; font-weight: 700;">
                {{ plan.price | formatPrice }}
              </span>
              <a href="/en/plans/{{ plan.slug_en or plan.slug }}/" class="btn btn-sm btn-secondary">
                View
              </a>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
