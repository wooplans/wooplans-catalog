---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Tarifs">
  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="section-title mb-4">Choisissez votre offre</h1>
        <p class="text-gray-600 text-lg">Accedez aux plans de distribution et devis de tous nos modeles</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Free -->
        <div class="card p-8">
          <h3 class="text-xl font-heading font-bold text-gray-700 mb-2">Visiteur</h3>
          <p class="text-gray-500 mb-6">Decouvrez nos modeles de plans</p>
          <div class="mb-6">
            <span class="text-4xl font-bold text-gray-700">Gratuit</span>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Voir le catalogue de plans</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Photos et descriptions</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span class="text-gray-400">Plans de distribution</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              <span class="text-gray-400">Devis detailles</span>
            </li>
          </ul>
          <a href="/plans" class="btn-outline w-full text-center">Voir le catalogue</a>
        </div>

        <!-- Premium -->
        <div class="card p-8 border-2 border-accent-500 relative">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent-500 text-primary-900 text-sm font-bold px-4 py-1 rounded-full">
            RECOMMANDE
          </span>
          <h3 class="text-xl font-heading font-bold text-primary-500 mb-2">Premium</h3>
          <p class="text-gray-500 mb-6">Acces complet aux plans et devis</p>
          <div class="mb-6">
            <span class="text-4xl font-bold text-primary-500">29 900</span>
            <span class="text-gray-500 ml-1">FCFA/an</span>
          </div>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Tout le catalogue de plans</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Plans de distribution detailles</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Devis detailles de construction</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Code PIN personnel securise</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-gray-600">Acces 1 an complet</span>
            </li>
          </ul>
          <div id="checkout-form">
            <form id="premium-form" class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Prenom</label>
                <input type="text" id="first_name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:outline-none" placeholder="Votre prenom" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nom</label>
                <input type="text" id="last_name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:outline-none" placeholder="Votre nom" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" id="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:outline-none" placeholder="votre@email.com" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Telephone</label>
                <input type="tel" id="phone" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent-500 focus:outline-none" placeholder="6XXXXXXXX" />
              </div>
              <button type="submit" id="submit-btn" class="btn-accent w-full text-lg py-4">
                S'abonner - 29 900 FCFA
              </button>
            </form>
            <p id="form-error" class="text-red-500 text-sm mt-3 hidden"></p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PublicLayout>

<script>
  const API = import.meta.env.PUBLIC_API_URL || "http://localhost:8787";

  document.getElementById("premium-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    const errorEl = document.getElementById("form-error");
    if (!btn || !errorEl) return;

    btn.disabled = true;
    btn.textContent = "Redirection vers le paiement...";
    errorEl.classList.add("hidden");

    const firstName = (document.getElementById("first_name") as HTMLInputElement).value;
    const lastName = (document.getElementById("last_name") as HTMLInputElement).value;
    const email = (document.getElementById("email") as HTMLInputElement).value;
    const phone = (document.getElementById("phone") as HTMLInputElement).value;

    try {
      const res = await fetch(`${API}/checkout/premium`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          first_name: firstName,
          last_name: lastName,
          email,
          phone,
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || "Erreur lors du paiement");
      }

      if (data.checkout_url) {
        window.location.href = data.checkout_url;
      }
    } catch (error: any) {
      errorEl.textContent = error.message;
      errorEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "S'abonner - 29 900 FCFA";
    }
  });
</script>
