---
import PublicLayout from "../layouts/PublicLayout.astro";

const email = Astro.url.searchParams.get("email") || "";
const pin = Astro.url.searchParams.get("pin") || "";
---

<PublicLayout title="Merci">
  <section class="py-20 bg-gray-50 min-h-screen flex items-center">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl shadow-lg p-10">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="text-3xl font-heading font-bold text-primary-500 mb-4">
          Paiement confirme !
        </h1>

        <p class="text-gray-600 mb-8">
          Votre abonnement premium est maintenant actif. Voici votre code d'acces :
        </p>

        <div id="pin-display" class="bg-primary-50 rounded-xl p-6 mb-8">
          <p class="text-sm text-gray-500 mb-2">Votre code PIN</p>
          <p class="text-4xl font-bold tracking-[0.5em] text-primary-500" id="pin-code">
            {pin || "------"}
          </p>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-8 text-left">
          <p class="text-sm text-amber-800">
            <strong>Important :</strong> Gardez ce code confidentiel. Un email contenant votre PIN a ete envoye a <strong id="user-email">{email}</strong>
          </p>
        </div>

        <a href={`/login?email=${encodeURIComponent(email)}`} class="btn-primary w-full text-center text-lg py-4">
          Se connecter au catalogue premium
        </a>
      </div>
    </div>
  </section>
</PublicLayout>
